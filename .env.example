VPN_SERVER_IPV4=203.0.113.1
VPN_PSK=your_pre_shared_key
VPN_USERNAME=vpnuser
VPN_PASSWORD=vpnpassword

# SOCKS5 proxy users — format: login:password
# Add or remove PROXY_USER_N lines as needed (N must be a positive integer).
# If none are defined, the proxy runs without authentication.
PROXY_USER_1=alice:s3cr3t
PROXY_USER_2=bob:hunter2
